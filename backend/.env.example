# =============================================
# Salin file ini menjadi .env dan isi nilainya
# cp .env.example .env
# =============================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/water_monitor
# Contoh: postgresql+asyncpg://user:pass@localhost:5432/nama_db

# --- App ---
APP_NAME="Water Monitor API"
APP_VERSION="1.0.0"
DEBUG=True

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Threshold level air (cm) ---
THRESHOLD_WASPADA=50
THRESHOLD_BAHAYA=100
